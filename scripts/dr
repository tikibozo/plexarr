#!/bin/bash

# Define container lists
GT_CONTAINERS="gluetun prowlarr autobrr lounge"
QBT_CONTAINERS="gluetun-qbt qbittorrent"

# Function to show usage
show_usage() {
    echo "Usage: $0 [OPTIONS] [CONTAINER_NAME ...]"
    echo "Restart Docker containers."
    echo
    echo "Options:"
    echo "  -g              Restart base gluetun containers"
    echo "  -q              Restart qbittorent containers"
    echo "  -h              Show this help message"
    echo
    echo "You may also specify one or more container names as arguments (after any options) to restart them."
}

# Function to restart containers
restart_containers() {
    local containers="$1"
    for container in $containers; do
        echo "Restarting container: $container"
        docker restart "$container"
    done
}

# Track whether any named option was triggered
named_option_used=false

# Parse options
while getopts ":gqh" opt; do
    case $opt in
        g)
            restart_containers "$GT_CONTAINERS"
            named_option_used=true
            ;;
        q)
            restart_containers "$QBT_CONTAINERS"
            named_option_used=true
            ;;
        h)
            show_usage
            exit 0
            ;;
        \?)
            echo "Invalid option: -$OPTARG" >&2
            show_usage
            exit 1
            ;;
    esac
done

# Shift off the options processed by getopts
shift $((OPTIND -1))

# If any non-option arguments remain, treat them as container names
if [ "$#" -gt 0 ]; then
    restart_containers "$*"
    exit 0
fi

# If no options or container names provided
if [ "$named_option_used" = false ]; then
    echo "No container names or options provided."
    show_usage
    exit 1
fi
